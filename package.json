{
  "name": "mathwithmagic",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint . --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "node node_modules/@playwright/test/cli.js test",
    "playwright:install": "node node_modules/@playwright/test/cli.js install chromium",
    "project:start": "bash scripts/start-project.sh",
    "project:complete": "bash scripts/complete-project.sh",
    "simulate:difficulty": "tsx scripts/simulate-difficulty.ts",
    "simulate:progression": "tsx scripts/analyze-progression.ts",
    "simulate:max-level": "tsx scripts/calculate-max-level-encounters.ts",
    "supabase:deploy": "bash scripts/deploy-supabase.sh",
    "stripe:local": "stripe listen --forward-to localhost:54321/functions/v1/stripe-webhook"
  },
  "dependencies": {
    "@stripe/react-stripe-js": "^5.6.1",
    "@stripe/stripe-js": "^8.9.0",
    "@supabase/supabase-js": "^2.99.1",
    "@tsparticles/engine": "^3.9.1",
    "@tsparticles/react": "^3.0.0",
    "framer-motion": "^12.36.0",
    "i18next": "^25.8.18",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.8",
    "react-router-dom": "^7.13.1",
    "tsparticles": "^3.9.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-basic-ssl": "^2.2.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.0",
"tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.2.4",
    "vitest": "^4.1.0"
  }
}
